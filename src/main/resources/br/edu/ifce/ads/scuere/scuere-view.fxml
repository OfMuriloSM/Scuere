<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane stylesheets="@styles.css" xmlns:fx="http://javafx.com/fxml" fx:controller="br.edu.ifce.ads.scuere.ScuereController">

    <top>
        <VBox alignment="CENTER" style="-fx-background-color: #0f172a; -fx-padding: 20;">
            <Label text="SCUERE MOTORS - GESTÃO" style="-fx-font-size: 26px; -fx-text-fill: white; -fx-font-weight: bold; -fx-letter-spacing: 2px;"/>
        </VBox>
    </top>

    <center>
        <TabPane tabClosingPolicy="UNAVAILABLE">

            <Tab text="Nova Venda">
                <VBox spacing="20.0" alignment="CENTER">
                    <padding><Insets top="30" right="50" bottom="30" left="50"/></padding>
                    <Label text="Lançar Venda" styleClass="titulo"/>
                    <Label text="Selecione o cliente e o veículo/peça do estoque" styleClass="subtitulo"/>

                    <HBox spacing="15" alignment="CENTER">
                        <TextField fx:id="campoCpfVenda" promptText="CPF do Cliente" prefWidth="250"/>
                        <ComboBox fx:id="comboTipoVenda" promptText="Categoria" prefWidth="180"/>
                    </HBox>

                    <HBox spacing="15" alignment="CENTER">
                        <ComboBox fx:id="comboIdItemVenda" promptText="Selecione o Item Disponível" prefWidth="445"/>
                    </HBox>

                    <Button text="Confirmar Venda" onAction="#realizarVendaCompleta" styleClass="button"/>
                    <Label fx:id="labelMensagemVenda" text="" styleClass="mensagem"/>
                </VBox>
            </Tab>

            <Tab text="Entrada de Motos">
                <VBox spacing="15.0" alignment="CENTER">
                    <padding><Insets top="30" right="50" bottom="30" left="50"/></padding>
                    <Label text="Cadastrar Motocicleta" styleClass="titulo"/>
                    <Label text="O sistema define Nova ou Usada baseado na quilometragem." styleClass="subtitulo"/>

                    <GridPane hgap="15" vgap="15" alignment="CENTER" style="-fx-padding: 20;">
                        <TextField fx:id="cadIdChassi" promptText="Chassi (Ex: 9BW...)" prefWidth="220" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                        <TextField fx:id="cadMarca" promptText="Marca (Ex: Honda)" prefWidth="220" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                        <TextField fx:id="cadModelo" promptText="Modelo (Ex: CB500)" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                        <TextField fx:id="cadAno" promptText="Ano de Fabricação" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                        <TextField fx:id="cadPreco" promptText="Preço Base (R$)" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                        <TextField fx:id="cadKm" promptText="Quilometragem (KM)" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                    </GridPane>

                    <Button text="Adicionar ao Pátio" onAction="#cadastrarMoto" styleClass="button"/>
                    <Label fx:id="labelMensagemMoto" text="" styleClass="mensagem"/>
                </VBox>
            </Tab>

            <Tab text="Entrada de Peças">
                <VBox spacing="15.0" alignment="CENTER">
                    <padding><Insets top="30" right="50" bottom="30" left="50"/></padding>
                    <Label text="Cadastrar Peça Avulsa" styleClass="titulo"/>

                    <GridPane hgap="15" vgap="15" alignment="CENTER" style="-fx-padding: 20;">
                        <TextField fx:id="cadIdPeca" promptText="Código da Peça (ID)" prefWidth="220" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                        <TextField fx:id="cadCompatibilidade" promptText="Compatibilidade (Ex: Universal)" prefWidth="220" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                        <TextField fx:id="cadPrecoPeca" promptText="Preço de Custo (R$)" GridPane.columnIndex="0" GridPane.rowIndex="1" GridPane.columnSpan="2" prefWidth="455"/>
                    </GridPane>

                    <Button text="Adicionar ao Estoque" onAction="#cadastrarPeca" styleClass="button"/>
                    <Label fx:id="labelMensagemPeca" text="" styleClass="mensagem"/>
                </VBox>
            </Tab>

            <Tab text="Oficina / Serviço">
                <VBox spacing="15.0" alignment="CENTER">
                    <padding><Insets top="30" right="50" bottom="30" left="50"/></padding>
                    <Label text="Ordem de Serviço" styleClass="titulo"/>

                    <TextArea fx:id="campoDescricaoServico" promptText="Descrição técnica do serviço realizado" prefRowCount="4" prefWidth="480" maxWidth="480"/>

                    <HBox spacing="15" alignment="CENTER">
                        <TextField fx:id="campoValorMaoObra" promptText="Mão de Obra (R$)" prefWidth="180"/>
                        <TextField fx:id="campoPecasUsadas" promptText="IDs das Peças aplicadas (separar por vírgula)" prefWidth="285"/>
                    </HBox>

                    <Button text="Emitir Nota de Serviço" onAction="#lancarServico" styleClass="button"/>
                    <Label fx:id="labelMensagemOficina" text="" styleClass="mensagem"/>
                </VBox>
            </Tab>

            <Tab text="Painel Financeiro">
                <VBox alignment="CENTER" spacing="30.0">
                    <padding><Insets top="40" bottom="40"/></padding>

                    <Label text="Visão Geral do Negócio" styleClass="titulo"/>

                    <HBox spacing="30" alignment="CENTER">
                        <VBox alignment="CENTER" spacing="10" styleClass="card" prefWidth="250">
                            <Label text="FATURAMENTO HOJE" styleClass="card-titulo"/>
                            <Label fx:id="labelCaixaHoje" text="R$ 0,00" styleClass="card-valor, valor-positivo"/>
                        </VBox>

                        <VBox alignment="CENTER" spacing="10" styleClass="card" prefWidth="250">
                            <Label text="FATURAMENTO ONTEM" styleClass="card-titulo"/>
                            <Label text="R$ 8.450,00" styleClass="card-valor, valor-neutro"/>
                        </VBox>

                        <VBox alignment="CENTER" spacing="10" styleClass="card" prefWidth="250">
                            <Label text="DESPESAS (MÊS)" styleClass="card-titulo"/>
                            <Label text="R$ 3.200,00" styleClass="card-valor, valor-alerta"/>
                        </VBox>
                    </HBox>
                </VBox>
            </Tab>

        </TabPane>
    </center>
</BorderPane>